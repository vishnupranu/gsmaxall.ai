# ──────────────────────────────────────────────────────────────────────────
# GSMAXALL — environment template. Copy to .env and fill in. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────

# --- Core infra (local docker-compose defaults) ---
DATABASE_URL=postgresql://gsmaxall:gsmaxall@localhost:5432/gsmaxall
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379

# --- Identity: Supabase Auth (blocker B1) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- AI provider keys (blocker B2 — at least one required for live chat) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Web app ---
NEXT_PUBLIC_APP_NAME=GSMAXALL
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8080

# --- Internal service-to-service auth ---
INTERNAL_SERVICE_TOKEN=change-me
